# 🌟 SuperNova - Plantilla de Configuración
# ⚠️ NO modifiques este archivo directamente.
# ✅ Crea una copia llamada .env y ajústala allí: cp .env.example .env

# 🤖 Motor de IA
MODEL_NAME=qwen2.5:7b
OLLAMA_HOST=http://localhost:11434
TEMPERATURE=0.3

# 🌐 API & Servidor
API_HOST=0.0.0.0
API_PORT=8000

# 💾 Memoria & Almacenamiento
MEMORY_PATH=./memory
BACKUP_ENABLED=true
LOG_LEVEL=INFO

# 🔐 Seguridad (Opcional para uso local)
# API_KEY=clave-secreta-opcional
# ALLOWED_ORIGINS=["http://localhost:8000", "http://localhost:3000"]
